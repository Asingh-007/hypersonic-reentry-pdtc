{
  "version": 6,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (vcpkg)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build",
      "environment": {
        "VCPKG_ROOT": "C:/vcpkg"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "ci",
      "displayName": "Ninja (GitHub Actions CI)",
      "description": "Used by .github/workflows/ci.yml. windows-latest runners don't expose a Visual Studio 'instance' vswhere/CMake's VS generator can find, even though the MSVC toolset is present -- Ninja + an explicit MSVC dev-environment setup (ilammy/msvc-dev-cmd) sidesteps that. Not for local use; the default preset already works locally.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "environment": {
        "VCPKG_ROOT": "C:/vcpkg"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "clangd-db",
      "displayName": "Ninja (compile_commands.json for clangd)",
      "description": "Not for building - just regenerate compile_commands.json for clangd. Run from a Developer Command Prompt (vcvarsall.bat) since the Ninja generator needs cl.exe/link.exe on PATH.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-clangd",
      "environment": {
        "VCPKG_ROOT": "C:/vcpkg"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC/14.44.35207/bin/Hostx64/x64/cl.exe",
        "CMAKE_CXX_COMPILER": "C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC/14.44.35207/bin/Hostx64/x64/cl.exe",
        "CMAKE_MT": "C:/Program Files (x86)/Windows Kits/10/bin/10.0.26100.0/x64/mt.exe",
        "CMAKE_C_COMPILER_WORKS": "1",
        "CMAKE_CXX_COMPILER_WORKS": "1"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "ci",
      "configurePreset": "ci"
    }
  ]
}
